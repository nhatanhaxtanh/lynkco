# Copy file này thành .env.local rồi điền giá trị thật (không commit .env.local)

# API key lấy tại https://resend.com/api-keys (bắt buộc để form đăng ký lái thử gửi mail)
RESEND_API_KEY=

# Email nhận lead. Bỏ trống thì dùng email trong lib/site-config.ts.
# Lưu ý: khi chưa xác thực domain trên Resend, chỉ gửi được TỚI đúng email
# của tài khoản Resend — hãy đăng ký Resend bằng chính email muốn nhận lead.
LEAD_EMAIL_TO=

# Địa chỉ gửi đi. Bỏ trống thì dùng onboarding@resend.dev (không cần xác thực domain).
LEAD_EMAIL_FROM=
